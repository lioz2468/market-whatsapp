# ── Claude ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── WhatsApp recipient ─────────────────────────────────
# Individual: +972501234567
# Group (Green API): 1234567890-1234567890@g.us
WHATSAPP_TO=+972501234567

# ── Twilio (אופציה A) ──────────────────────────────────
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token

# שליחה ישירה ממספר (Sandbox: +14155238886 | Production: המספר שאושר)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Production: Content Template מאושר (HX...) — נדרש לפתיחת שיחה ב-WhatsApp Business
# הטמפלייט צריך להכיל משתנה אחד {{1}} שמקבל את טקסט ההודעה.
# TWILIO_CONTENT_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Production: Messaging Service (MG...) — אלטרנטיבה ל-TWILIO_WHATSAPP_FROM
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Green API (אופציה B) ──────────────────────────────
GREEN_API_INSTANCE=1234567890
GREEN_API_TOKEN=your_token_here

# ── Optional overrides ────────────────────────────────
# DEFAULT_PROVIDER=twilio          # twilio | green
# MIN_IMPORTANCE_SCORE=6           # 1-10, only send if >= this
# MAX_CONCURRENT_CLAUDE=5
# DIGEST_HOURS=12                  # lookback window for --morning-digest
# CLAUDE_MODEL=claude-sonnet-4-0
